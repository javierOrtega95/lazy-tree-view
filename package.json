{
  "name": "lazy-tree-view",
  "version": "1.0.2",
  "description": "A lightweight, zero-dependency React tree view with lazy loading, drag & drop, and keyboard navigation.",
  "author": "Javier Ortega",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/javierOrtega95/lazy-tree-view.git"
  },
  "homepage": "https://github.com/javierOrtega95/lazy-tree-view#readme",
  "bugs": {
    "url": "https://github.com/javierOrtega95/lazy-tree-view/issues"
  },
  "keywords": [
    "react",
    "tree",
    "tree-view",
    "treeview",
    "lazy-loading",
    "drag-and-drop",
    "keyboard-navigation",
    "accessible",
    "aria",
    "typescript",
    "lightweight",
    "zero-dependencies",
    "expandable",
    "collapsible",
    "hierarchy"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/blocks": "8.6.18",
    "@storybook/manager-api": "^8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@storybook/theming": "^8.6.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "eslint-plugin-storybook": "^0.11.1",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "8.6.18",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.34.4 <5",
      "esbuild": ">=0.25.0 <1",
      "picomatch": ">=2.3.2 <5",
      "flatted": ">=3.4.2 <4",
      "form-data": ">=4.0.2 <5",
      "minimatch": ">=3.1.5 <10"
    }
  }
